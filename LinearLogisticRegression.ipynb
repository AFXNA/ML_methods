        "    print(\"Single Feature\")\n",
        "    print(f\"Threshold {t}: Accuracy {acc:.4f}\")\n",
        "    print(\"Multi Feature\")\n",
        "    print(f\"Threshold {t}: Accuracy {acc1:.4f}\")\n",
        "\n"
