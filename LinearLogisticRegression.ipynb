    {
      "cell_type": "code",
      "source": [
        "#3.1 Logistic Regression\n",
        "class LogisticRegressionNumPy:\n",
        "    def __init__(self, learning_rate=0.01, iterations=1000):\n",
        "        self.lr = learning_rate\n",
        "        self.iterations = iterations\n",
        "        self.beta1 = None\n",
        "        self.beta0 = None\n",
        "        self.loss_history = []\n",
        "\n",
        "    def sigmoid(self, z):\n",
        "        return 1 / (1 + np.exp(-z))\n",
        "\n",
        "    def cross_entropy_loss(self, y_true, y_pred):\n",
        "        epsilon = 1e-15\n",
        "        y_pred = np.clip(y_pred, epsilon, 1 - epsilon)\n",
        "        return -np.mean(y_true * np.log(y_pred) + (1 - y_true) * np.log(1 - y_pred))\n",
        "\n",
        "    def fit(self, X, y):\n",
        "        n_samples, n_features = X.shape\n",
        "        self.beta1 = np.zeros((n_features, 1))\n",
        "        self.beta0 = 0\n",
        "\n",
        "        for _ in range(self.iterations):\n",
        "            z = np.dot(X, self.beta1) + self.beta0\n",
        "            y_pred = self.sigmoid(z)\n",
        "\n",
        "            d_beta1 = (1 / n_samples) * np.dot(X.T, (y_pred - y))\n",
        "            d_beta0 = (1 / n_samples) * np.sum(y_pred - y)\n",
        "\n",
        "            self.beta1 -= self.lr * d_beta1\n",
        "            self.beta0 -= self.lr * d_beta0\n",
        "            self.loss_history.append(self.cross_entropy_loss(y, y_pred))\n",
        "\n",
        "    def predict_proba(self, X):\n",
        "        z = np.dot(X, self.beta1) + self.beta0\n",
        "        return self.sigmoid(z)\n",
        "\n",
        "    def predict(self, X, threshold=0.5):\n",
        "        return (self.predict_proba(X) >= threshold).astype(int)\n",
        "\n",
        "simple_log = LogisticRegressionNumPy(learning_rate=0.1, iterations=3000)\n",
        "simple_log.fit(X_train_simple_norm, y_train_class)\n",
        "acc_simple = np.mean(simple_log.predict(X_test_simple_norm) == y_test_class)\n",
